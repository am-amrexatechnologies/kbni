<mvc:View xmlns:cards="sap.f.cards" xmlns:f="sap.f" controllerName="kobeni.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <f:DynamicPage id="idMainPage" showFooter="true">
        <f:title>
            <f:DynamicPageTitle id="idMainPageTitle">
                <f:content>
                    <Title id="idMainPageTitleText" text="KBNI"></Title>
                </f:content>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader id="idMainPageHeader">
                <f:content>
                    <Button id="idMainPageHeaderLoginButton" text="login"></Button>
                    <Button id="idMainPageHeaderRegisterButton" text="registrieren"></Button>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            
        </f:content>
        <f:footer>
            <Toolbar id="adsiujfh">
                <Button id="idFooterBarImpressumButton" text="Impressum" press="onImpressumPress"></Button>
            </Toolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>